[Unit]
Description=RedNotebook API
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/rednotebook-api
ExecStart=/opt/rednotebook-api/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
# change line below to point to your rednotebook data folder
Environment=REDNOTEBOOK_DIR=/path/to/rednotebook/data
[Install]
WantedBy=multi-user.target
